<x:xmpmeta xmlns:x="adobe:ns:meta/" xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#">
  <rdf:RDF>
    <rdf:Description>
      <Name>Vintage Film Muted</Name>
      <Author>Recipe Test Suite</Author>
      <Desc>Vintage film-inspired preset with muted colors and warm tones</Desc>
      <Exposure>-0.1</Exposure>
      <Contrast>-5</Contrast>
      <Saturation>-20</Saturation>
      <Temperature>18</Temperature>
      <Tint>-8</Tint>
      <Clarity>-10</Clarity>
      <ShadowsHue>25</ShadowsHue>
      <ShadowsSaturation>15</ShadowsSaturation>
      <MidtonesHue>40</MidtonesHue>
      <MidtonesSaturation>25</MidtonesSaturation>
      <HighlightsHue>55</HighlightsHue>
      <HighlightsSaturation>20</HighlightsSaturation>
    </rdf:Description>
  </rdf:RDF>
</x:xmpmeta>
