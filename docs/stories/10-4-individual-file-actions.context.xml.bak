    <constraints>
    <constraint type="architecture">All processing must remain client-side (WASM) - no server uploads</constraint>
    <constraint type="performance">Individual conversions must complete in <100ms per file</constraint>
    <constraint type="browser">Must support Chrome 90+, Firefox 88+, Safari 14+, Edge 90+ (AbortController required)</constraint>
    <constraint type="dependencies">Zero external JavaScript libraries - vanilla JS only</constraint>
    <constraint type="concurrency">Sequential processing (one file at a time) to prevent memory pressure</constraint>
    <constraint type="ui">Dropdown must show only valid target formats (exclude source format)</constraint>
    <constraint type="state">File status must persist across user interactions (queued, processing, complete, error)</constraint>
    <constraint type="accessibility">Keyboard navigation required (Tab through controls, Enter to convert)</constraint>
  </constraints>
