    <ideas>
      <test id="AC-1" type="manual">
        <description>Per-file format selection dropdown</description>
        <steps>
          1. Upload NP3 file → Verify dropdown shows XMP, lrtemplate, Capture One, DCP (4 options, source excluded)
          2. Upload XMP file → Verify dropdown shows NP3, lrtemplate, Capture One, DCP
          3. Verify dropdown disabled during "processing" state
          4. Verify dropdown hidden when "complete" state
        </steps>
      </test>
      <test id="AC-2" type="manual">
        <description>Individual "Convert" button</description>
        <steps>
          1. Upload 3 files → Verify each has "Convert" button
          2. Click "Convert" on file 2 → Verify only file 2 processes (files 1 and 3 remain queued)
          3. Verify button disabled during "processing" state
          4. Verify button hidden when "complete" state (replaced by download)
        </steps>
      </test>
      <test id="AC-3" type="manual">
        <description>Individual file conversion flow</description>
        <steps>
          1. Upload 5 files → Select different formats for each
          2. Convert file 3 first (not sequential) → Verify only file 3 processes
          3. Convert file 1, then file 5 → Verify sequential processing works
          4. Verify batch progress: "3 of 5 converted"
        </steps>
      </test>
      <test id="AC-4" type="manual">
        <description>Mixed format conversion support</description>
        <steps>
          1. Upload 3 files (NP3, XMP, lrtemplate)
          2. Select: NP3 → XMP, XMP → DCP, lrtemplate → NP3
          3. Convert all → Verify each downloads with correct format
          4. Verify filenames: preset_converted.xmp, style_converted.dcp, template_converted.np3
        </steps>
      </test>
      <test id="AC-5" type="manual">
        <description>Retry failed conversions</description>
        <steps>
          1. Upload corrupted file → Verify conversion fails → "Retry" button appears
          2. Click "Retry" → Verify conversion re-attempts
          3. Retry 5 times → Verify no limit on retry attempts
          4. Verify error message clears when retry starts
        </steps>
      </test>
      <test id="AC-6" type="manual">
        <description>Batch vs individual conversion coexistence</description>
        <steps>
          1. Upload 10 files → Batch convert 5 to XMP
          2. Individually convert 3 to DCP → Verify both work together
          3. Verify batch progress: "8 of 10 converted"
          4. Verify no conflict when triggering batch and individual simultaneously
        </steps>
      </test>
      <test id="AC-7" type="manual">
        <description>Individual file cancellation</description>
        <steps>
          1. Start conversion → Click "Cancel" during "processing" state
          2. Verify status reverts to "queued"
          3. Verify "Convert" button reappears
          4. Verify cancelling file doesn't affect other files
          5. Verify no confirmation dialog for individual cancel
        </steps>
      </test>
      <test id="Edge-Case-1" type="manual">
        <description>AbortController not supported</description>
        <steps>
          1. Test in old browser (simulate by disabling AbortController)
          2. Verify cancel button hidden if AbortController unsupported
          3. Verify conversions still work (cancel feature gracefully degrades)
        </steps>
      </test>
      <test id="Edge-Case-2" type="manual">
        <description>User changes format dropdown mid-conversion</description>
        <steps>
          1. Start conversion → Try to change format dropdown
          2. Verify dropdown disabled (no effect)
        </steps>
      </test>
      <test id="Edge-Case-3" type="manual">
        <description>User removes file during conversion</description>
        <steps>
          1. Start conversion → Click "Remove" during "processing"
          2. Verify graceful cleanup (no errors in console)
          3. Verify conversion aborts cleanly
        </steps>
      </test>
    </ideas>
  </tests>
</story-context>