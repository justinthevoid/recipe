{
	"name": "recipe",
	"private": true,
	"workspaces": [
		"extension",
		"webview"
	],
	"catalog": {
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	},
	"scripts": {
		"lint": "biome check extension/ webview/",
		"lint:fix": "biome check --write extension/ webview/",
		"dev": "bun run --filter '*' dev",
		"build": "bun run build:go && bun run --filter '@recipe/webview' build && bun run --filter '@recipe/extension' build",
		"build:go": "go build -o extension/bin/np3tool ./cmd/np3tool/",
		"build:extension": "bun run --filter '@recipe/extension' build",
		"build:webview": "bun run --filter '@recipe/webview' build"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4"
	}
}