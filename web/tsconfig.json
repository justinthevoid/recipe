{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"skipLibCheck": true,
		"paths": {
			"$lib": ["./src/lib"],
			"$lib/*": ["./src/lib/*"]
		}
	},
	"include": ["src/**/*", "src/**/*.svelte", "src/**/*.astro"],
	"exclude": ["node_modules"]
}
